
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	//Начало.Чекалева_ЕА Вывод на форму команды о применении скидки 
	
	ПолеВвода = Элементы.Добавить("СогласованнаяСкидка", Тип("ПолеФормы"), Элементы.ГруппаШапкаЛево);
	ПолеВвода.Вид = ВидПоляФормы.ПолеВвода;
	ПолеВвода.ПутьКДанным = "Объект.ДЗ_СогласованнаяСкидка"; 
	
	ПолеВвода.УстановитьДействие("ПриИзменении", "ПриИзмененииСогласованнойСкидки");
	

	Если Элементы.Найти("КнопкаПересчитатьСуму") = Неопределено Тогда
		//Добавляю команду
		Команда = Команды.Добавить("ПересчитатьСумму");
		Команда.Заголовок = "Пересчитать сумму";  
		Команда.Действие = "КомандаПересчитатьСумму"; 
		
		//Добавляю кнопку на форму
		КнопкаФормы = Элементы.Добавить("КнопкаПересчитатьСумму", Тип("КнопкаФормы"), ЭтаФорма.Элементы.ГруппаШапкаЛево);
		КнопкаФормы.ИмяКоманды = "ПересчитатьСумму";
		КнопкаФормы.Вид = ВидКнопкиФормы.ОбычнаяКнопка;  
	КонецЕсли;
	//Конец.Чекалева_ЕА
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
    // СтандартныеПодсистемы.ПодключаемыеКоманды
    ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
    // Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
    // СтандартныеПодсистемы.ПодключаемыеКоманды
    ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
    // Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

//Начало.Чекалева_ЕА 

&НаКлиенте
Процедура ПриИзмененииСогласованнойСкидки(Элемент) 
	
	//Проверка на заполнение табличной части 
	СтрокиТовары = Объект.Товары.Количество();
	СтрокиУслуги = Объект.Услуги.Количество();

	
	Если СтрокиТовары = 0 И СтрокиУслуги = 0 Тогда
		Сообщить("Данные о товарах или услугах в таблицу не внесены");
		Возврат;
	КонецЕсли; 
	
		
	Оповещение = Новый ОписаниеОповещения("ОбработкаОтвета", ЭтотОбъект);
	
	ПоказатьВопрос(Оповещение, "Размер скидки был изменен. Применить новую скидку?", РежимДиалогаВопрос.ДаНет);  
	
	
Конецпроцедуры  


&НаКлиенте
Процедура КомандаПересчитатьСумму(Команда) 
	
	ПересчитатьСумму(); 
	

КонецПроцедуры   

&НаКлиенте
Процедура ПересчитатьСумму() 
	
	
	Для Каждого Строка Из Объект.Товары Цикл
		РассчитатьСуммуСтроки(Строка); 
	КонецЦикла;
	
	
	Для Каждого Строка Из Объект.Услуги Цикл
		РассчитатьСуммуСтроки(Строка);
	КонецЦикла;

	
КонецПроцедуры 

&НаКлиенте 
Процедура ОбработкаОтвета(Ответ, Параметры) Экспорт 
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ПересчитатьСумму();
	КонецЕсли;
	
КонецПроцедуры

//Конец.Чекалева_ЕА  
 

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
    ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
КонецПроцедуры

#КонецОбласти

